{
  "name": "@iamrobot/desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "dependencies": {
    "@iamrobot/agent-claude": "workspace:*",
    "@iamrobot/agent-codex": "workspace:*",
    "@iamrobot/orchestration": "workspace:*",
    "@iamrobot/protocol": "workspace:*",
    "@iamrobot/ui": "workspace:*",
    "electron": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false ."
  }
}
